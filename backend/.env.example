NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://user:password@localhost:5432/theconnection"

# Auth
JWT_SECRET=change-me
# Access tokens are short-lived (15m, set in code); refresh tokens last this many days.
JWT_REFRESH_EXPIRES_DAYS=30
FRONTEND_URL=http://localhost:3000

# Email verification
EMAIL_CODE_TTL_MINUTES=10
MAIL_FROM="TheConnection <no-reply@theconnection.co>"

# Availability links (HU-09) — how long the tokenized WhatsApp link stays valid.
AVAILABILITY_LINK_TTL_HOURS=72

# SMTP — leave SMTP_HOST blank in dev to log verification codes and match
# notification emails to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

OPENAI_API_KEY=

# WhatsApp chatbot (AI brain)
# OpenRouter key — chat completions run through an OpenAI-compatible endpoint.
OPENROUTER_API_KEY=
CHATBOT_MODEL=openai/gpt-4o-mini
CHATBOT_REQUEST_TIMEOUT_MS=9000
CHATBOT_MEMORY_TTL_SECONDS=1800

# WhatsApp outbound transport (in progress). Leave WHATSAPP_TOKEN blank in dev to
# log the availability invite link to the console instead of sending it.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Admin venue-management access — comma-separated allowlist of admin emails
ADMIN_EMAILS=
