model Venue {
  id                    String   @id @default(cuid())
  name                  String
  type                  String
  address               String
  openingHours          String
  description           String
  commissionRate        Float
  averageSpentPerPerson Float
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  dates        Date[]
  venueOptions VenueOption[]
}
