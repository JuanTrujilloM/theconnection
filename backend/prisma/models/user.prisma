model User {
  id         String   @id @default(uuid())
  email      String   @unique
  cellphone  String   @unique
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  profile             Profile?
  preferences         Preferences?
  matchesAsUserA      Match[]        @relation("MatchUserA")
  matchesAsUserB      Match[]        @relation("MatchUserB")
  availabilities      Availability[]
  feedbacks           Feedback[]
  venueOptionsAsUserA VenueOption[]  @relation("VenueOptionUserA")
  venueOptionsAsUserB VenueOption[]  @relation("VenueOptionUserB")
  reportsAsUserA      Report[]       @relation("ReportUserA")
  reportsAsUserB      Report[]       @relation("ReportUserB")
}
